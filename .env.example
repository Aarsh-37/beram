
# Direct connection — used by Prisma CLI (db push, db seed, studio)
DATABASE_URL="postgresql://username:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Pooled connection — used by the app at runtime (better for serverless)
# Get this from Neon dashboard with "Pooled connection" toggle ON
DATABASE_URL_POOLED="postgresql://username:password@ep-xxx-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
NODE_ENV="development"
